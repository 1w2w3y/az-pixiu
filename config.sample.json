{
  "provider": "foundry",
  "foundry": {
    "endpoint": "https://<your-foundry-resource>.openai.azure.com",
    "deployment": "<your-deployment-name>"
  },
  "litellm": {
    "endpoint": "https://litellm.your-domain.com",
    "model": "gpt-5.6-sol"
  },
  "amg": {
    "endpoint": "https://<your-amg-instance>.grafana.azure.com",
    "auth": {
      "mode": "entra"
    }
  },
  "observability": {
    "application_insights_connection_string": "InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/;ApplicationId=<app-id>"
  },
  "billing_cache": {
    "enabled": true,
    "stabilization_offset_days": 5,
    "invoice_close_horizon_months": 2,
    "cost_view": "amortized"
  }
}
