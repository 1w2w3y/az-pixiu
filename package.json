{
  "name": "az-pixiu",
  "version": "0.1.0",
  "description": "Local, read-only, observability-first Azure FinOps agent",
  "type": "module",
  "private": true,
  "bin": {
    "pixiu": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "cost-summary": "tsx src/cli.ts analyze cost-summary --subscription-name-filter GrafanaDevRP",
    "eval:compare": "tsx src/cli.ts eval eval/phase-1.json --use-playbook --observability langfuse --experiment-name 7-model-compare --models gpt-4o,gpt-4.1,gpt-5-mini,gpt-5.4,gpt-chat-latest,DeepSeek-V4-Flash,DeepSeek-V4-Pro"
  },
  "dependencies": {
    "@arizeai/openinference-instrumentation-mcp": "^0.2.16",
    "@arizeai/openinference-instrumentation-openai": "^4.1.1",
    "@arizeai/openinference-semantic-conventions": "^2.3.0",
    "@azure/identity": "^4.13.1",
    "@langfuse/core": "^5.3.0",
    "@langfuse/openai": "^5.3.0",
    "@langfuse/otel": "^5.3.0",
    "@langfuse/tracing": "^5.3.0",
    "@microsoft/opentelemetry": "^1.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.218.0",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@traceloop/instrumentation-mcp": "^0.26.0",
    "openai": "^6.38.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
