# Operator-local config (per design doc §15.8). Use config.sample.json
# as the checked-in template; this file holds the operator's real endpoints.
config.json

# Node toolchain
node_modules/
dist/

# Per-run output (per design doc §15.6) — both the canonical `runs/`
# directory and operator-chosen sibling directories (e.g.
# `runs-pr1pr2-verify/`, `runs-modelcompare/`) used for ad-hoc
# verification or cross-model sweeps.
runs/
runs-*/

# Local environment overrides
.env
.env.local

# Claude Code isolated worktrees (auto-created under .claude/worktrees/;
# each has its own .git and must never be committed as a gitlink)
.claude/worktrees/

# Editor
.vscode/
.idea/
*.swp
.DS_Store

config.json.bak-*
